\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b 98% 848 - dataset anemia/Italy/96/T_65_20190613_075213.jpg\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b                                                           \b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bEverything is Ok\n","\n","Files: 865\n","Size:       684245102\n","Compressed: 666269625\n","Italy  : True\n","Train  : 560 images\n","Val    : 30 images\n","Test   : 30 images\n","\n","Ready for Day 5 — Custom CNN!\n"]}],"source":["#  Session starter\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","import os, json, cv2, numpy as np, random\n","\n","# Re-extract dataset\n","if not os.path.exists('/content/fresh_dataset/dataset anemia/Italy'):\n","    print(\"Extracting dataset...\")\n","    !apt-get install -y p7zip-full -q\n","    !7z x /content/drive/MyDrive/anemia_project/dataset_clean.zip -o/content/fresh_dataset -y\n","\n","# Load saved data\n","DRIVE_PATH = '/content/drive/MyDrive/anemia_project'\n","with open(os.path.join(DRIVE_PATH, 'split_info.json'), 'r') as f:\n","    split_info = json.load(f)\n","\n","train_paths  = split_info['train_paths']\n","val_paths    = split_info['val_paths']\n","test_paths   = split_info['test_paths']\n","train_labels = split_info['train_labels']\n","val_labels   = split_info['val_labels']\n","test_labels  = split_info['test_labels']\n","\n","def preprocess(img_path):\n","    img = cv2.imread(img_path)\n","    if img is None: return None\n","    img = cv2.resize(img, (224, 224))\n","    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)\n","    l, a, b = cv2.split(lab)\n","    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))\n","    l = clahe.apply(l)\n","    img = cv2.merge([l, a, b])\n","    img = cv2.cvtColor(img, cv2.COLOR_LAB2RGB)\n","    return img.astype(np.float32) / 255.0\n","\n","def augment(image):\n","    img = (image * 255).astype(np.uint8)\n","    if random.random() > 0.5:\n","        img = cv2.flip(img, 1)\n","    angle = random.uniform(-20, 20)\n","    h, w  = img.shape[:2]\n","    M     = cv2.getRotationMatrix2D((w//2, h//2), angle, 1.0)\n","    img   = cv2.warpAffine(img, M, (w, h), borderMode=cv2.BORDER_REFLECT)\n","    factor = random.uniform(0.75, 1.25)\n","    img    = np.clip(img.astype(np.float32) * factor, 0, 255).astype(np.uint8)\n","    return img.astype(np.float32) / 255.0\n","\n","# Rebuild folders\n","BASE_DIR = '/content/data'\n","for split in ['train', 'val', 'test']:\n","    for cls in ['anemic', 'normal']:\n","        os.makedirs(os.path.join(BASE_DIR, split, cls), exist_ok=True)\n","\n","def save_img(img, folder, fname):\n","    img_uint8 = (img * 255).astype(np.uint8)\n","    cv2.imwrite(os.path.join(folder, fname),\n","                cv2.cvtColor(img_uint8, cv2.COLOR_RGB2BGR))\n","\n","for i, (path, label) in enumerate(zip(train_paths, train_labels)):\n","    cls = 'anemic' if label == 1 else 'normal'\n","    orig = preprocess(path)\n","    save_img(orig, os.path.join(BASE_DIR, 'train', cls), f\"{i:04d}_orig.png\")\n","    for j in range(3):\n","        save_img(augment(orig), os.path.join(BASE_DIR, 'train', cls), f\"{i:04d}_aug{j}.png\")\n","\n","for i, (path, label) in enumerate(zip(val_paths, val_labels)):\n","    cls = 'anemic' if label == 1 else 'normal'\n","    save_img(preprocess(path), os.path.join(BASE_DIR, 'val', cls), f\"{i:04d}.png\")\n","\n","for i, (path, label) in enumerate(zip(test_paths, test_labels)):\n","    cls = 'anemic' if label == 1 else 'normal'\n","    save_img(preprocess(path), os.path.join(BASE_DIR, 'test', cls), f\"{i:04d}.png\")\n","\n","print(f\"Italy  : {os.path.exists('/content/fresh_dataset/dataset anemia/Italy')}\")\n","print(f\"Train  : {sum(len(os.listdir(os.path.join(BASE_DIR,'train',c))) for c in ['anemic','normal'])} images\")\n","print(f\"Val    : {sum(len(os.listdir(os.path.join(BASE_DIR,'val',c))) for c in ['anemic','normal'])} images\")\n","print(f\"Test   : {sum(len(os.listdir(os.path.join(BASE_DIR,'test',c))) for c in ['anemic','normal'])} images\")\n","print()\n","print(\" Custom CNN!\")"]},{"cell_type":"code","source":["#  Keras Data Generators\n","import tensorflow as tf\n","from tensorflow.keras.preprocessing.image import ImageDataGenerator\n","import os\n","\n","BASE_DIR = '/content/data'\n","\n","# Rescale only — augmentation already done in folders\n","datagen = ImageDataGenerator(rescale=1.0/255.0)\n","\n","train_gen = datagen.flow_from_directory(\n","    os.path.join(BASE_DIR, 'train'),\n","    target_size=(224, 224),\n","    batch_size=16,\n","    class_mode='binary',\n","    shuffle=True,\n","    seed=42\n",")\n","\n","val_gen = datagen.flow_from_directory(\n","    os.path.join(BASE_DIR, 'val'),\n","    target_size=(224, 224),\n","    batch_size=16,\n","    class_mode='binary',\n","    shuffle=False\n",")\n","\n","test_gen = datagen.flow_from_directory(\n","    os.path.join(BASE_DIR, 'test'),\n","    target_size=(224, 224),\n","    batch_size=16,\n","    class_mode='binary',\n","    shuffle=False\n",")\n","\n","print(f\"Class indices : {train_gen.class_indices}\")\n","print(f\"Train batches : {len(train_gen)}\")\n","print(f\"Val batches   : {len(val_gen)}\")\n","print(f\"Test batches  : {len(test_gen)}\")\n","print()\n","print(f\"TensorFlow version: {tf.__version__}\")\n","print(\"Generators ready!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yV3xYcqAEEXf","executionInfo":{"status":"ok","timestamp":1777094145778,"user_tz":-300,"elapsed":8062,"user":{"displayName":"AMINA Asif yaqoob","userId":"06931508334072087891"}},"outputId":"1b0a9e38-617a-4cde-f9a2-96bd20d336bf"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Found 560 images belonging to 2 classes.\n","Found 30 images belonging to 2 classes.\n","Found 30 images belonging to 2 