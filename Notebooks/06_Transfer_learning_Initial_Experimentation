00e-04\n","Epoch 9: early stopping\n","Restoring model weights from the end of the best epoch: 1.\n","\n","EfficientNetB0 best val_accuracy: 63.3%\n","MobileNetV2 best val_accuracy   : 86.7%\n"]}]},{"cell_type":"code","source":["#  EfficientNetB0 FINAL\n","# do NOT rescale to [0,1]\n","tf.keras.backend.clear_session()\n","\n","from tensorflow.keras.preprocessing.image import ImageDataGenerator\n","from tensorflow.keras.applications import EfficientNetB0\n","from tensorflow.keras.applications.efficientnet import preprocess_input\n","from tensorflow.keras.models import Model\n","from tensorflow.keras.layers import GlobalAveragePooling2D, Dense, Dropout\n","\n","# NO rescale for EfficientNet , use its own preprocess_input\n","train_gen_eff = ImageDataGenerator(\n","    preprocessing_function=preprocess_input\n",").flow_from_directory(\n","    '/content/data/train', target_size=(224,224),\n","    batch_size=16, class_mode='binary', shuffle=True, seed=42)\n","\n","val_gen_eff = ImageDataGenerator(\n","    preprocessing_function=preprocess_input\n",").flow_from_directory(\n","    '/content/data/val', target_size=(224,224),\n","    batch_size=16, class_mode='binary', shuffle=False)\n","\n","test_gen_eff = ImageDataGenerator(\n","    preprocessing_function=preprocess_input\n",").flow_from_directory(\n","    '/content/data/test', target_size=(224,224),\n","    batch_size=16, class_mode='binary', shuffle=False)\n","\n","class_weight = {0: 125/75, 1: 1.0}\n","\n","print(f\"Train: {train_gen_eff.n} | Val: {val_gen_eff.n} | Test: {test_gen_eff.n}\")\n","print()\n","\n","# Build model  freeze first 100 layers\n","base_eff = EfficientNetB0(weights='imagenet', include_top=False,\n","                           input_shape=(224,224,3))\n","for layer in base_eff.layers[:100]:\n","    layer.trainable = False\n","for layer in base_eff.layers[100:]:\n","    layer.trainable = True\n","\n","inputs = tf.keras.Input(shape=(224,224,3))\n","x      = base_eff(inputs, training=True)\n","x      = GlobalAveragePooling2D()(x)\n","x      = Dense(256, activation='relu')(x)\n","x      = Dropout(0.5)(x)\n","x      = Dense(128, activation='relu')(x)\n","x      = Dropout(0.3)(x)\n","output = Dense(1, activation='sigmoid')(x)\n","\n","model_eff = Model(inputs=inputs, outputs=output)\n","model_eff.compile(\n","    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-4),\n","    loss='binary_crossentropy',\n","    metrics=['accuracy']\n",")\n","\n","print(f\"Frozen : {sum(1 for l in base_eff.layers if not l.trainable)}\")\n","print(f\"Trainable : {sum(1 for l in base_eff.layers if l.trainable)}\")\n","print()\n","\n","callbacks_eff = [\n","    tf.keras.callbacks.EarlyStopping(\n","        monitor='val_accuracy', patience=8,\n","        restore_best_weights=True, verbose=1),\n","    tf.keras.callbacks.ModelCheckpoint(\n","        os.path.join(models_dir, 'efficientnet_final.keras'),\n","        monitor='val_accuracy', save_best_only=True, verbose=1),\n","    tf.keras.callbacks.ReduceLROnPlateau(\n","        monitor='val_loss', factor=0.3,\n","        patience=4, min_lr=1e-8, verbose=1)\n","]\n","\n","print(\"Training EfficientNetB0 with correct preprocessing...\")\n","print(\"This is the real run вЂ” expect 85%+ now...\")\n","print()\n","\n","history_eff = model_eff.fit(\n","    train_gen_eff,\n","    epochs=30,\n","    validation_data=val_gen_eff,\n","    callbacks=callbacks_eff,\n","    class_weight=class_weight,\n","    verbose=1\n",")\n","\n","print()\n","print(f\"EfficientNetB0 best val_accuracy : {max(history_eff.history['val_accuracy'])*100:.1f}%\")\n","print(f\"MobileNetV2 best val_accuracy    : 86.7%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"TBmAfdrqaGsU","executionInfo":{"status":"ok","timestamp":1777101414112,"user_tz":-300,"elapsed":938536,"user":{"displayName":"AMINA Asif yaqoob","userId":"06931508334072087891"}},"outputId":"6fd12751-3e18-4791-ad4e-b41e1707e36a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"s