, target_size=(224,224),\n","    batch_size=16, class_mode='binary', shuffle=False)\n","class_weight = {0: 125/75, 1: 1.0}\n","\n","# Load EfficientNetB0 вЂ” unfreeze everything\n","base_efficient = EfficientNetB0(\n","    weights='imagenet',\n","    include_top=False,\n","    input_shape=(224, 224, 3)\n",")\n","\n","# Freeze only first 100 layers, unfreeze the rest\n","for layer in base_efficient.layers[:100]:\n","    layer.trainable = False\n","for layer in base_efficient.layers[100:]:\n","    layer.trainable = True\n","\n","# Build model\n","inputs = tf.keras.Input(shape=(224, 224, 3))\n","x      = base_efficient(inputs, training=True)\n","x      = GlobalAveragePooling2D()(x)\n","x      = Dense(256, activation='relu')(x)\n","x      = Dropout(0.5)(x)\n","x      = Dense(128, activation='relu')(x)\n","x      = Dropout(0.3)(x)\n","output = Dense(1, activation='sigmoid')(x)\n","\n","model_efficient = Model(inputs=inputs, outputs=output)\n","\n","# Very low lr вЂ” critical for EfficientNet fine-tuning\n","model_efficient.compile(\n","    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-4),\n","    loss='binary_crossentropy',\n","    metrics=['accuracy']\n",")\n","\n","frozen    = sum(1 for l in base_efficient.layers if not l.trainable)\n","trainable = sum(1 for l in base_efficient.layers if l.trainable)\n","print(f\"Base frozen    : {frozen}\")\n","print(f\"Base trainable : {trainable}\")\n","print()\n","\n","callbacks_eff = [\n","    EarlyStopping(monitor='val_accuracy', patience=8,\n","                  restore_best_weights=True, verbose=1),\n","    ModelCheckpoint(\n","        os.path.join(models_dir, 'efficientnet_final.keras'),\n","        monitor='val_accuracy', save_best_only=True, verbose=1),\n","    ReduceLROnPlateau(monitor='val_loss', factor=0.3,\n","                      patience=4, min_lr=1e-8, verbose=1)\n","]\n","\n","print(\"Training EfficientNetB0 вЂ” partial fine-tuning from start...\")\n","print(\"Takes 8-12 minutes...\")\n","print()\n","\n","hist