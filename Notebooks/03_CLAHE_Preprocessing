_paths, val_labels)):\n","    cls    = 'anemic' if label == 1 else 'normal'\n","    folder = os.path.join(BASE_DIR, 'val', cls)\n","    fname  = f\"{i:04d}.png\"\n","    save_preprocessed(path, folder, fname)\n","    val_count += 1\n","\n","# Process test set — NO augmentation\n","test_count = 0\n","for i, (path, label) in enumerate(zip(test_paths, test_labels)):\n","    cls    = 'anemic' if label == 1 else 'normal'\n","    folder = os.path.join(BASE_DIR, 'test', cls)\n","    fname  = f\"{i:04d}.png\"\n","    save_preprocessed(path, folder, fname)\n","    test_count += 1\n","\n","print(\"Done!\")\n","print()\n","print(\"Final image counts:\")\n","for split in ['train', 'val', 'test']:\n","    for cls in ['anemic', 'normal']:\n","        folder = os.path.join(BASE_DIR, split, cls)\n","        count  = len(os.listdir(folder))\n","        print(f\"  {split}/{cls}: {count} images\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_yc_Lu8Wajqf","executionInfo":{"status":"ok","timestamp":1776932256193,"user_tz":-300,"elapsed":8517,"user":{"displayName":"AMINA Asif yaqoob","userId":"06931508334072087891"}},"outputId":"ed28cec6-ee70-4a01-e065-3e3d929fd5c4"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Folders created:\n","  /content/data/train/anemic/\n","  /content/data/train/normal/\n","  /content/data/val/anemic/\n","  /content/data/val/normal/\n","  /content/data/test/anemic/\n","  /content/data/test/normal/\n","\n","Copying and preprocessing images...\n","This takes 2-3 minutes...\n","Done!\n","\n","Final image counts:\n","  train/anemic: 212 images\n","  train/normal: 348 images\n","  val/anemic: 11 images\n","  val/normal: 19 images\n","  test/anemic: 11 images\n","  test/normal: 19 images\n"]}]},{"cell_type":"code","source":["#Save split info and final checklist\n","import json\n","import os\n","\n","DRIVE_PATH = '/content/drive/MyDrive/anemia_project'\n","\n","# Save split paths for future days\n","split_info