 RGB to LAB color space\n","    4. Apply CLAHE on L channel (contrast enhancement)\n","    5. Convert back to RGB\n","    6. Normalize to [0, 1]\n","    \"\"\"\n","    # Step 1 - Load\n","    img = cv2.imread(img_path)\n","    if img is None:\n","        print(f\"WARNING: Could not load {img_path}\")\n","        return None\n","\n","    # Step 2 - Resize\n","    img = cv2.resize(img, (224, 224))\n","\n","    # Step 3 - BGR to LAB\n","    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)\n","\n","    # Step 4 - Split LAB, apply CLAHE on L channel only\n","    l, a, b = cv2.split(lab)\n","    clahe   = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))\n","    l       = clahe.apply(l)\n","\n","    # Step 5 - Merge back and convert to RGB\n","    lab = cv2.merge([l, a, b])\n","    img = cv2.cvtColor(lab, cv2.COLOR_LAB2RGB)\n","\n","    # Step 6 - Normalize to [0, 1]\n","    img = img.astype(np.float32) / 255.0\n","\n","    return img\n","\n","# Quick test on one image\n","sample_path = list(image_label_dict.keys())[0]\n","result      = preprocess(sample_path)\n","\n","print(f\"Input image  : {sample_path}\")\n","print(f\"Output shape : {result.shape}\")\n","print(f\"Value range  : {result.min():.3f} to {result.max():.3f}\")\n","print()\n","print(\"Preprocessing function works!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SGN-f4L4YVRQ","executionInfo":{"status":"ok","timestamp":1776931663019,"user_tz":-300,"elapsed":661,"user":{"displayName":"AMINA Asif yaqoob","userId":"06931508334072087891"}},"outputId":"232390d2-408a-4352-e688-8f872fb58723"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Input image  : /content/fresh_dataset/dataset anemia/Italy/1/001_palpebral.png\n","Output shape : (224, 224, 3)\n","Value range  : 0.184 to 1.000\n","\n","Preprocessing function works!\n"]}]},{"cell_type":"code","source":["# CLAHE Before vs After Visualization\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","def load_original(img_path):\n","    \"\"\"Load image resized but WITHOUT CLAHE — for comparison\"\"\"\n","    img = cv2.imread(img_path)\n","    img = cv2.resize(img, (224, 224))\n","    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","    return img.astype(np.float32) / 255.0\n","\n","# Pick 4 images — 2 anemic, 2 normal\n","anemic_paths = [p for p, l in image_label_dict.items() if l == 1][:2]\n","normal_paths = [p for p, l in image_label_dict.items() if l == 0][:2]\n","sample_paths = anemic_paths + normal_paths\n","sample_labels = ['Anemic', 'Anemic', 'Normal', 'Normal']\n","\n","fig, axes = plt.subplots(4, 2, figsize=(10, 18))\n","fig.suptitle('CLAHE Preprocessing — Before vs After\\n(This is your Computer Vision step)',\n","             fontsize=13, fontweight='bold')\n","\n","for row, (img_path, label) in enumerate(zip(sample_paths, sample_labels)):\n","    original = load_original(img_path)\n","    enhanced = preprocess(img_path)\n","    patient  = os.path.basename(os.path.dirname(img_path))\n","    color    = '#A32D2D' if label == 'Anemic' else '#085041'\n","\n","    # Before\n","    axes[row, 0].imshow(original)\n","    axes[row, 0].set_title(f'BEFORE CLAHE\\n{label} — Patient {patient}',\n","                            color=color, fontsize=10, fontweight='bold')\n","    axes[row, 0].axis('off')\n","\n","    # After\n","    axes[row, 1].imshow(enhanced)\n","    axes[row, 1].set_title(f'AFTER CLAHE\\n{label} — Patient {patient}',\n","                            color=color, fontsize=10, fontweight='bold')\n","    axes[row, 1].axis('off')\n","\n","plt.tight_layout()\n","\n","# Save to Drive\n","out = '/content/drive/MyDrive/anemia_project/clahe_comparison.png'\n","plt.savefig(out, dpi=120, bbox_inches='tight')\n","plt.show()\n","print(\"Saved: clahe_comparison.png\")\n","print()\n","print(\"USE THIS IMAGE ON SLIDE 5 OF YOUR PRESENTATION\")\n","print(\"When professor asks 'where is CV?' — show this slide\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"a7ybe3BDYg5O","executionInfo":{"status":"ok","timestamp":1776931715910,"user_tz":-300,"elapsed":4683,"user":{"displayName":"AMINA Asif yaqoob","userId":"06931508334072087891"}},"outputId":"2adda64d-3fd9-4acb-f988-24235d98e0d5"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x1800 with 8 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saved: clahe_comparison.png\n","\n","USE THIS IMAGE ON SLIDE 5 OF YOUR PRESENTATION\n","When professor asks 'where is CV?' — show this slide\n"]}]},{"cell_type":"code","source":["#  Augmentation Pipeline\n","import cv2\n","import numpy as np\n","import random\n","import os\n","\n","def augment(image):\n","    \"\"\"\n","    Apply random augmentation to one image.\n","    Input : numpy array (224, 224, 3) float32 [0,1]\n","    Output: augmented numpy array same shape\n","    \"\"\"\n","    img = (image * 255).astype(np.uint8)\n","\n","    # Random horizontal flip\n","    if random.random() > 0.5:\n","        img = cv2.flip(img, 1)\n","\n","    # Random rotation between -20 and +20 degrees\n","    angle = random.uniform(-20, 20)\n","    h, w  = img.shape[:2]\n","    M     = cv2.getRotationMatrix2D((w//2, h//2), angle, 1.0)\n","    img   = cv2.warpAffine(img, M, (w, h),\n","                            borderMode=cv2.BORDER_REFLECT)\n","\n","    # Random brightness adjustment\n","    factor = random.uniform(0.75, 1.25)\n","    img    = np.clip(img.astype(np.float32) * factor, 0, 255).astype(np.uint8)\n","\n","    # Random zoom (0.9 to 1.1)\n","    scale  = random.uniform(0.9, 1.1)\n","    new_h  = int(h * scale)\n","    new_w  = int(w * scale)\n","    img    = cv2.resize(img, (new_w, new_h))\n","    # Crop or pad back to 224x224\n","    if scale > 1.0:\n","        start_h = (new_h - h) // 2\n","        start_w = (new_w - w) // 2\n","        img = img[start_h:start_h+h, start_w:start_w+w]\n","    else:\n","        pad_h = (h - new_h) // 2\n","        pad_w = (w - new_w) // 2\n","        img   = cv2.copyMakeBorder(img, pad_h, h-new_h-pad_h,\n","                                   pad_w, w-new_w-pad_w,\n","                                   cv2.BORDER_REFLECT)\n","\n","    img = cv2.resize(img, (224, 224))\n","    return img.astype(np.float32) / 255.0\n","\n","\n","# Test augmentation on one image\n","sample_path = list(image_label_dict.keys())[0]\n","original    = preprocess(sample_path)\n","\n","fig, axes = plt.subplots(1, 5, figsize=(18, 4))\n","fig.suptitle('Original + 4 Augmented Versions of Same Image', fontsize=12)\n","\n","axes[0].imshow(original)\n","axes[0].set_title('Original\\n(CLAHE applied)', fontsize=9)\n","axes[0].axis('off')\n","\n","for i in range(1, 5):\n","    aug = augment(original)\n","    axes[i].imshow(aug)\n","    axes[i].set_title(f'Augmented {i}', fontsize=9)\n","    axes[i].axis('off')\n","\n","plt.tight_layout()\n","out = '/content/drive/MyDrive/anemia_project/augmentation_samples.png'\n","plt.savefig(out, dpi=120, bbox_inches='tight')\n","plt.show()\n","print(\"Saved: augmentation_samples.png\")\n","print()\n","print(\"Each original image becomes 4 augmented versions\")\n","print(\"200 images x 4 = 800 training images total\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":399},"id":"2f0UNfJFZbo-","executionInfo":{"status":"ok","timestamp":1776931963047,"user_tz":-300,"elapsed":3955,"user":{"displayName":"AMINA Asif yaqoob","userId":"06931508334072087891"}},"outputId":"5d4b412f-121d-47df-97e7-0443fa320914"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x400 with 5 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saved: augmentation_samples.png\n","\n","Each original image becomes 4 augmented versions\n","200 images x 4 = 800 training images total\n"]}]},{"cell_type":"code","source":["# Build Train/Val/Test Split\n","impo