l.png\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b                                                                               \b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b 99% 860 - dataset anemia/Italy/99/T_68_20190613_081143.jpg\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b                                                           \b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bEverything is Ok\n","\n","Files: 865\n","Size:       684245102\n","Compressed: 666269625\n","Italy  : True\n","India  : True\n","Total images : 200\n","Anemic (1)   : 75\n","Normal (0)   : 125\n","\n","TensorFlow: 2.19.0\n","Ready for optimized training!\n"]}],"source":["#  Session Starter\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","import os, json, cv2, numpy as np, random\n","import tensorflow as tf\n","\n","DRIVE_PATH = '/content/drive/MyDrive/anemia_project'\n","\n","# Extract Eyes Defy Anemia\n","if not os.path.exists('/content/fresh_dataset/dataset anemia/Italy'):\n","    print(\"Extracting dataset...\")\n","    !apt-get install -y p7zip-full -q\n","    !7z x /content/drive/MyDrive/anemia_project/dataset_clean.zip \\\n","          -o/content/fresh_dataset -y\n","\n","# Load Eyes Defy labels only\n","with open(os.path.join(DRIVE_PATH, 'image_labels.json'), 'r') as f:\n","    image_label_dict = json.load(f)\n","\n","all_paths  = list(image_label_dict.keys())\n","all_labels = list(image_label_dict.values())\n","\n","print(f\"Italy  : {os.path.exists('/content/fresh_dataset/dataset anemia/Italy')}\")\n","print(f\"India  : {os.path.exists('/content/fresh_dataset/dataset anemia/India')}\")\n","print(f\"Total images : {len(all_paths)}\")\n","print(f\"Anemic (1)   : {sum(all_labels)}\")\n","print(f\"Normal (0)   : {all_labels.count(0)}\")\n","print()\n","print(\"TensorFlow:\", tf.__version__)\n","print(\"Ready \")"]},{"cell_type":"code","source":["# 5-Fold Cross Validation with MobileNetV2\n","import numpy as np\n","import cv2, os, json, random, gc\n","import tensorflow as tf\n","from tensorflow.keras.applications import MobileNetV2\n","from tensorflow.keras.applications.mobilenet_v2 import preprocess_input\n","from tensorflow.keras.models import Model\n","from tensorflow.keras.layers import GlobalAveragePooling2D, Dense, Dropout\n","from tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau\n","from sklearn.model_selection import StratifiedKFold\n","from sklearn.metrics import (accuracy_score, f1_score,\n","                             roc_auc_score, precision_score, recall_score)\n","\n","DRIVE_PATH = '/content/drive/MyDrive/anemia_project'\n","models_dir = os.path.join(DRIVE_PATH, 'models')\n","os.makedirs(models_dir, exist_ok=True)\n","\n","# Load all images into memory with correct preprocessing\n","print(\"Loading all 200 images into memory...\")\n","print(\"Using MobileNetV2 preprocess_input (no CLAHE for DL)\")\n","print()\n","\n","def load_image(path):\n","    \"\"\"Load image with MobileNetV2 correct preprocessing\"\"\"\n","    img = cv2.imread(path)\n","    if img is None:\n","        return np.zeros((224,224,3), dtype=np.float32)\n","    img = cv2.resize(img, (224,224))\n","    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","    img = preprocess_input(img.astype(np.float32))\n","    return img\n","\n","def augment(img):\n","    \"\"\"Augment a preprocessed image\"\"\"\n","    # Reverse preprocess to augment in uint8 space\n","    img_uint8 = np.clip(((img + 1) / 2 * 255), 0, 255).astype(np.uint8)\n","    if random.random() > 0.5:\n","        img_uint8 = cv2.flip(img_uint8, 1)\n","    angle = random.uniform(-15, 15)\n","    h, w  = img_uint8.shape[:2]\n","    M     = cv2.getRotationMatrix2D((w//2,h//2), angle, 1.0)\n","    img_uint8 = cv2.warpAffine(img_uint8, M, (w,h),\n","                               borderMode=cv2.BORDER_REFLECT)\n","    factor = random.uniform(0.85, 1.15)\n","    img_uint8 = np.clip(img_uint8.astype(np.float32)*factor,\n","                        0, 255).astype(np.uint8)\n","    return preprocess_input(img_uint8.astype(np.float32))\n","\n","X_all = np.array([load_image(p) for p in all_paths])\n","y_all = np.array(all_labels)\n","\n","print(f\"X_all shape : {X_all.shape}\")\n","print(f\"dtype       : {X_all.dtype}\")\n","print(f\"value range : {X_all.min():.2f} to {X_all.max():.2f}\")\n","print()\n","\n","def build_model():\n","    tf.keras.backend.clear_session()\n","    base = MobileNetV2(weights='imagenet', include_top=False,\n","                       input_shape=(224,224,3))\n","    base.trainable = False\n","    x      = base.output\n","    x      = GlobalAveragePooling2D()(x)\n","    x      = Dense(256, activation='relu')(x)\n","    x      = Dropout(0.4)(x)\n","    x      = Dense(128, activation='relu')(x)\n","    x      = Dropout(0.3)(x)\n","    output = Dense(1, activation='sigmoid')(x)\n","    model  = Model(inputs=base.input, outputs=output)\n","    return model, base\n","\n","def make_batch(paths_idx, augment_flag=False, bs=32):\n","    \"\"\"Generate batches on the fly\"\"\"\n","    for i in range(0, len(paths_idx), bs):\n","        batch_idx = paths_idx[i:i+bs]\n","        X = X_all[batch_idx].copy()\n","        if augment_flag:\n","            X = np.array([augment(x) for x in X])\n","        y = y_all[batch_idx]\n","        yield X, y\n","\n","# 5-Fold Cross Validation\n","skf     = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n","results = []\n","\n","print(\"Starting 5-Fold Cross Validation...\")\n","print(\"Each fold: Stage1 (10 epochs) + Stage2 (15 epochs)\")\n","print(\"Expected time: ~8-10 minutes per fold\")\n","print()\n","\n","best_fold_acc  = 0\n","best_fold_idx  = 0\n","\n","for fold, (train_idx, test_idx) in enumerate(skf.split(X_all, y_all)):\n","    print(f\"{'='*45}\")\n","    print(f\"  FOLD {fold+1}/5\")\n","    print(f\"{'='*45}\")\n","\n","    # Further split train into train+val\n","    val_size   = int(len(train_idx) * 0.15)\n","    val_idx    = train_idx[:val_size]\n","    train_idx2 = train_idx[val_size:]\n","\n","    print(f\"  Train: {len(train_idx2)} | Val: {len(val_idx)} | Test: {len(test_idx)}\")\n","\n","    # Class weight\n","    n_pos = int(y_all[train_idx2].sum())\n","    n_neg = len(train_idx2) - n_pos\n","    cw    = {0: n_neg/n_pos if n_pos > 0 else 1.0, 1: 1.0}\n","\n","    # Build model\n","    model, base = build_model()\n","    model.compile(\n","        optimizer=tf.keras.optimizers.Adam(1e-3),\n","        loss='binary_crossentropy',\n","        metrics=['accuracy']\n","    )\n","\n","    #  Stage 1 — train head\n","    X_train = X_all[train_idx2]\n","    y_train = y_all[train_idx2]\n","    X_val   = X_all[val_idx]\n","    y_val   = y_all[val_idx]\n","    X_test  = X_all[test_idx]\n","    y_test  = y_all[test_idx]\n","\n","    # Augment training data\n","    X_train_aug = np.vstack([\n","        X_train,\n","        np.array([augment(x) for x in X_train]),\n","        np.array([augment(x) for x in X_train])\n","    ])\n","    y_train_aug = np.hstack([y_train, y_train, y_train])\n","\n","    print(f\"  Augmented train: {len(X_train_aug)} images\")\n","    print(f\"  Stage 1 training...\")\n","\n","    s1_cb = [\n","        EarlyStopping(monitor='val_accuracy', patience=5,\n","                      restore_best_weights=True, verbose=0),\n","        ReduceLROnPlateau(monitor='val_loss', factor=0.5,\n","                         patience=3, min_lr=1e-7, verbose=0)\n","    ]\n","\n","    model.fit(X_train_aug, y_train_aug,\n","              epochs=15, batch_size=32,\n","              validation_data=(X_val, y_val),\n","              callbacks=s1_cb,\n","              class_weight=cw,\n","              verbose=0)\n","\n","    s1_val = model.evaluate(X_val, y_val, verbose=0)[1]\n","    print(f\"  Stage 1 val_acc: {s1_val*100:.1f}%\")\n","\n","    #  Stage 2 — fine-tune\n","    base.trainable = True\n","    for layer in base.layers[:-40]:\n","        layer.trainable = False\n","\n","    model.compile(\n","        optimizer=tf.keras.optimizers.Adam(1e-5),\n","        loss='binary_crossentropy',\n","        metrics=['accuracy']\n","    )\n","\n","    s2_cb = [\n","        EarlyStopping(monitor='val_accuracy', patience=6,\n","                      restore_best_weights=True, verbose=0),\n","        ReduceLROnPlateau(monitor='val_loss', factor=0.3,\n","                         patience=3, min_lr=1e-8, verbose=0)\n","    ]\n","\n","    print(f\"  Stage 2 fine-tuning...\")\n","    model.fit(X_train_aug, y_train_aug,\n","              epochs=20, batch_size=32,\n","              validation_data=(X_val, y_val),\n","              callbacks=s2_cb,\n","              class_weight=cw,\n","              verbose=0)\n","\n","    # Evaluate on test fold\n","    y_prob = model.predict(X_test, verbose=0).flatten()\n","    y_pred = (y_prob > 0.5).astype(int)\n","\n","    acc  = accuracy_score(y_test, y_pred)\n","    f1   = f1_score(y_test, y_pred, zero_division=0)\n","    auc  = roc_auc_score(y_test, y_prob)\n","    prec = precision_score(y_test, y_pred, zero_division=0)\n","    rec  = recall_score(y_test, y_pred, zero_division=0)\n","\n","    results.append({\n","        'fold': fold+1,\n","        'acc' : acc,\n","        'f1'  : f1,\n","        'auc' : auc,\n","        'prec': prec,\n","        'rec' : rec\n","    })\n","\n","    print(f\"  Test Accuracy : {acc*100:.1f}%\")\n","    print(f\"  F1 Score      : {f1*100:.1f}%\")\n","    print(f\"  AUC           : {auc:.3f}\")\n","    print()\n","\n","    # Save best fold model\n","    if acc > best_fold_acc:\n","        best_fold_acc = acc\n","        best_fold_idx = fold\n","        model.save(os.path.join(models_dir, 'mobilenet_optimized_best.keras'))\n","        print(f\"   Best model saved (Fold {fold+1})\")\n","\n","    # Free memory\n","    del model, base, X_train_aug\n","    gc.collect()\n","    tf.keras.backend.clear_session()\n","\n","# Final results\n","print()\n","print(\"=\"*50)\n","print(\"  MOBILENETV2 — 5-FOLD CV FINAL RESULTS\")\n","print(\"=\"*50)\n","mean_acc  = np.mean([r['acc']  for r in results])\n","std_acc   = np.std([r['acc']   for r in results])\n","mean_f1   = np.mean([r['f1']   for r in results])\n","mean_auc  = np.mean([r['auc']  for r in results])\n","mean_prec = np.mean([r['prec'] for r in results])\n","mean_rec  = np.mean([r['rec']  for r in results])\n","\n","print(f\"  Accuracy  : {mean_acc*100:.1f}% ± {std_acc*100:.1f}%\")\n","print(f\"  F1 Score  : {mean_f1*100:.1f}%\")\n","print(f\"  AUC       : {mean_auc:.3f}\")\n","print(f\"  Precision : {mean_prec*100:.1f}%\")\n","print(f\"  Recall    : {mean_rec*100:.1f}%\")\n","print()\n","print(f\"  Per-fold breakdown:\")\n","for r in results:\n","    print(f\"    Fold {r['fold']}: Acc={r['acc']*100:.1f}%  \"\n","          f\"F1={r['f1']*100:.1f}%  AUC={r['auc']:.3f}\")\n","print()\n","print(f\"  Best model saved from Fold {best_fold_idx+1}\")\n","print(f\"  File: models/mobilenet_optimized_best.keras\")\n","print(\"=\"*50)\n","\n","# Save results\n","with open(os.path.join(DRIVE_PATH, 'config.json'), 'r') as f:\n","    config = json.load(f)\n","config['final_results'] = {\n","    'model'    : 'MobileNetV2',\n","    'method'   : '5-Fold Cross Validation',\n","    'accuracy' : f\"{mean_acc*100:.1f}%±{std_acc*100:.1f}%\",\n","    'f1'       : f\"{mean_f1*100:.1f}%\",\n","    'auc'      : f\"{mean_auc:.3f}\",\n","    'precision': f\"{mean_prec*100:.1f}%\",\n","    'recall'   : f\"{mean_rec*100:.1f}%\"\n","}\n","with open(os.path.join(DRIVE_PATH, 'config.json'), 'w') as f:\n","    json.dump(config, f, indent=2)\n","print(\"Results saved to config!\")"],"metadata":{"colab":{"base_uri":"https://loc